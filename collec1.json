    {
      "name": "creer  produit Copy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"vérifier le code status\",function(){\r",
              "    let code_attendu=200;\r",
              "    let code_obtenu=pm.response.code\r",
              "    //assertions\r",
              "    pm.expect(code_attendu).equal(code_obtenu)\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"vérifier les données envoyé  avec la reponse\",function(){\r",
              "\r",
              "    //recupérer  body request\r",
              "    let body_req=JSON.parse(pm.request.body.raw)\r",
              "    let name_req=body_req.name\r",
              "    let year_req=body_req.data.year\r",
              "    let price_req=body_req.data.price\r",
              "    let cpu_model_req=body_req.data[\"CPU model\"]\r",
              "    //recupérer body response\r",
              "    let body_res=pm.response.json()\r",
              "    let name_res=body_res.name;\r",
              "    let year_res=body_res.data.year\r",
              "    let price_res=body_res.data.price\r",
              "    let cpu_model_res=body_res.data[\"CPU model\"]\r",
              "    //faire les assertions (verification)\r",
              "    pm.expect(name_req).equal(name_res)\r",
              "    pm.expect(year_req).equal(year_res)\r",
              "    pm.expect(price_req).equal(price_res)\r",
              "    pm.expect(cpu_model_req).equal(cpu_model_res)\r",
              "    \r",
              "    let id_res=body_res.id\r",
              "    pm.collectionVariables.set(\"id_objet\",id_res)\r",
              "    pm.collectionVariables.set(\"year_post\",year_res)\r",
              "    pm.collectionVariables.set(\"cpu_post\",cpu_model_res)\r",
              "\r",
              "})\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let year_random= Math.floor(Math.random()*18)+2009\r",
              "pm.collectionVariables.set(\"year_random\",year_random);\r",
              "\r",
              "let price_random=Math.random()*1906.96+104.35\r",
              "pm.collectionVariables.set(\"price_random\",price_random.toFixed(2));\r",
              ""
            ],
